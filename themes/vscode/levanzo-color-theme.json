  "tokenColors": [
    // ── Base text & punctuation ───────────────────────────────
    // Plain text: deep espresso — maximum contrast on parchment
    {
      "scope": ["source", "text"],
      "settings": { "foreground": "#1E1410" }
    },
    {
      "scope": ["punctuation", "meta.brace", "punctuation.separator", "punctuation.terminator"],
      "settings": { "foreground": "#6A5848" }
    },

    // ── Comments — muted, clearly subordinate ────────────────
    // Noticeably lighter than everything else so they recede
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#A89A82", "fontStyle": "italic" }
    },
    {
      "scope": ["comment.block.documentation"],
      "settings": { "foreground": "#A89A82", "fontStyle": "italic" }
    },

    // ── Strings — rich teal-green ─────────────────────────────
    // Clearly distinct from function calls (warm brown) — different hue entirely
    {
      "scope": ["string", "string.quoted", "string.template", "string.interpolated"],
      "settings": { "foreground": "#245C40" }
    },
    {
      "scope": ["constant.character.escape"],
      "settings": { "foreground": "#7A5010", "fontStyle": "bold" }
    },
    {
      "scope": ["punctuation.definition.template-expression", "punctuation.section.embedded"],
      "settings": { "foreground": "#8C3A18" }
    },
    {
      "scope": ["string.regexp", "constant.other.character-class.regexp"],
      "settings": { "foreground": "#7A5010" }
    },
    {
      "scope": ["keyword.operator.quantifier.regexp", "keyword.control.anchor.regexp", "punctuation.definition.group.regexp"],
      "settings": { "foreground": "#8C3A18" }
    },

    // ── Numbers — deep amber ──────────────────────────────────
    {
      "scope": ["constant.numeric", "constant.other.numeric"],
      "settings": { "foreground": "#7A5010" }
    },
    {
      "scope": ["constant.language", "variable.language.this", "variable.language.super", "variable.language.self"],
      "settings": { "foreground": "#245C40", "fontStyle": "italic" }
    },
    {
      "scope": ["constant.other"],
      "settings": { "foreground": "#7A5010" }
    },

    // ── Keywords — deep brick, bold ───────────────────────────
    // Most saturated + heaviest weight = unmistakable control flow
    {
      "scope": ["keyword", "keyword.control", "keyword.operator.new"],
      "settings": { "foreground": "#7A2010", "fontStyle": "bold" }
    },
    {
      "scope": ["keyword.control.import", "keyword.control.export", "keyword.control.from", "keyword.control.as", "keyword.control.of", "keyword.control.in"],
      "settings": { "foreground": "#7A2010", "fontStyle": "bold" }
    },
    {
      "scope": ["keyword.control.return", "keyword.control.throw", "keyword.control.yield"],
      "settings": { "foreground": "#7A2010", "fontStyle": "bold italic" }
    },
    {
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#6A5848" }
    },
    {
      "scope": ["keyword.operator.assignment"],
      "settings": { "foreground": "#6A5848" }
    },
    {
      "scope": ["storage.type.function.arrow", "keyword.operator.arrow"],
      "settings": { "foreground": "#7A2010" }
    },
    {
      "scope": ["storage", "storage.type"],
      "settings": { "foreground": "#7A2010", "fontStyle": "bold" }
    },
    {
      "scope": ["storage.modifier"],
      "settings": { "foreground": "#7A2010", "fontStyle": "bold italic" }
    },

    // ── Functions — warm sienna, clearly different from strings ─
    // Hue sits between brick (keywords) and amber (numbers)
    {
      "scope": ["entity.name.function", "meta.function entity.name.function"],
      "settings": { "foreground": "#1E1410", "fontStyle": "bold" }
    },
    {
      "scope": ["meta.function-call entity.name.function", "variable.function"],
      "settings": { "foreground": "#8C4A20" }
    },
    {
      "scope": ["support.function", "support.function.builtin"],
      "settings": { "foreground": "#8C4A20" }
    },
    {
      "scope": ["meta.method-call entity.name.function", "support.function.method"],
      "settings": { "foreground": "#8C4A20" }
    },

    // ── Types / classes — deep gold/amber ─────────────────────
    // Distinct from both keywords (brick) and strings (green)
    {
      "scope": ["entity.name.class", "entity.name.type", "entity.name.type.class", "support.class", "support.type"],
      "settings": { "foreground": "#6B4A08" }
    },
    {
      "scope": ["entity.other.inherited-class"],
      "settings": { "foreground": "#7A5A10", "fontStyle": "italic" }
    },
    {
      "scope": ["meta.type.annotation", "entity.name.type.ts", "entity.name.type.parameter"],
      "settings": { "foreground": "#6B4A08" }
    },
    {
      "scope": ["entity.name.type.interface"],
      "settings": { "foreground": "#7A5A10" }
    },
    {
      "scope": ["entity.name.namespace", "entity.name.module", "entity.name.type.module"],
      "settings": { "foreground": "#1E1410" }
    },

    // ── Variables ─────────────────────────────────────────────
    {
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#1E1410" }
    },
    {
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#5C3E28", "fontStyle": "italic" }
    },
    {
      "scope": ["variable.other.property", "variable.other.object.property", "meta.object-literal.key"],
      "settings": { "foreground": "#1E1410" }
    },
    {
      "scope": ["variable.other.constant"],
      "settings": { "foreground": "#7A5010" }
    },

    // ── Decorators ────────────────────────────────────────────
    {
      "scope": ["meta.decorator", "punctuation.decorator", "entity.name.function.decorator", "storage.type.function.decorator"],
      "settings": { "foreground": "#7A5010", "fontStyle": "italic" }
    },

    // ── HTML / JSX ────────────────────────────────────────────
    {
      "scope": ["entity.name.tag", "meta.tag entity.name.tag"],
      "settings": { "foreground": "#8C2E10", "fontStyle": "bold" }
    },
    {
      "scope": ["entity.other.attribute-name", "meta.tag entity.other.attribute-name"],
      "settings": { "foreground": "#7A5010" }
    },
    {
      "scope": ["string.quoted.double.html", "string.quoted.single.html"],
      "settings": { "foreground": "#2E5828" }
    },
    {
      "scope": ["support.class.component", "entity.name.tag.jsx", "entity.name.tag.tsx"],
      "settings": { "foreground": "#6B4A08" }
    },
    {
      "scope": ["punctuation.section.embedded.begin.jsx", "punctuation.section.embedded.end.jsx"],
      "settings": { "foreground": "#8C2E10" }
    },

    // ── CSS ───────────────────────────────────────────────────
    {
      "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css", "entity.name.tag.css"],
      "settings": { "foreground": "#7A5010" }
    },
    {
      "scope": ["support.type.property-name.css", "meta.property-name"],
      "settings": { "foreground": "#1E1410" }
    },
    {
      "scope": ["support.constant.property-value.css", "meta.property-value"],
      "settings": { "foreground": "#2E5828" }
    },
    {
      "scope": ["keyword.other.unit.css", "constant.numeric.css"],
      "settings": { "foreground": "#7A5010" }
    },
    {
      "scope": ["variable.css", "support.type.custom-property", "support.type.variable-name.css"],
      "settings": { "foreground": "#8C2E10" }
    },
    {
      "scope": ["keyword.control.at-rule", "keyword.other.at-rule"],
      "settings": { "foreground": "#8C2E10", "fontStyle": "bold italic" }
    },
    {
      "scope": ["entity.other.pseudo-class.css", "entity.other.pseudo-element.css"],
      "settings": { "foreground": "#7A3A18" }
    },

    // ── Markdown ──────────────────────────────────────────────
    {
      "scope": ["markup.heading", "entity.name.section.markdown"],
      "settings": { "foreground": "#1E1410", "fontStyle": "bold" }
    },
    {
      "scope": ["punctuation.definition.heading.markdown"],
      "settings": { "foreground": "#8C2E10" }
    },
    {
      "scope": ["markup.bold"],
      "settings": { "foreground": "#1E1410", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.italic"],
      "settings": { "foreground": "#1E1410", "fontStyle": "italic" }
    },
    {
      "scope": ["markup.inline.raw", "markup.raw.inline"],
      "settings": { "foreground": "#2E5828" }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": { "foreground": "#8C2E10" }
    },
    {
      "scope": ["string.other.link.title.markdown"],
      "settings": { "foreground": "#7A3A18" }
    },
    {
      "scope": ["markup.quote"],
      "settings": { "foreground": "#7A6858", "fontStyle": "italic" }
    },
    {
      "scope": ["punctuation.definition.list.begin.markdown", "markup.list.bullet"],
      "settings": { "foreground": "#8C2E10" }
    },

    // ── JSON ──────────────────────────────────────────────────
    {
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#8C2E10" }
    },
    {
      "scope": ["string.quoted.json"],
      "settings": { "foreground": "#2E5828" }
    },
    {
      "scope": ["constant.numeric.json"],
      "settings": { "foreground": "#7A5010" }
    },
    {
      "scope": ["constant.language.json"],
      "settings": { "foreground": "#2E5828", "fontStyle": "italic" }
    },

    // ── YAML ──────────────────────────────────────────────────
    {
      "scope": ["entity.name.tag.yaml"],
      "settings": { "foreground": "#8C2E10" }
    },
    {
      "scope": ["string.unquoted.yaml", "string.quoted.yaml"],
      "settings": { "foreground": "#2E5828" }
    },
    {
      "scope": ["entity.name.type.anchor.yaml", "variable.other.alias.yaml"],
      "settings": { "foreground": "#7A5010" }
    },

    // ── Python ────────────────────────────────────────────────
    {
      "scope": ["entity.name.function.decorator.python"],
      "settings": { "foreground": "#7A5010", "fontStyle": "italic" }
    },
    {
      "scope": ["variable.language.special.self.python"],
      "settings": { "foreground": "#2E5828", "fontStyle": "italic" }
    },

    // ── Rust ──────────────────────────────────────────────────
    {
      "scope": ["storage.modifier.lifetime.rust", "entity.name.lifetime.rust"],
      "settings": { "foreground": "#7A5010", "fontStyle": "italic" }
    },
    {
      "scope": ["entity.name.function.macro.rust", "support.macro.rust"],
      "settings": { "foreground": "#7A3A18" }
    },
    {
      "scope": ["storage.modifier.unsafe.rust"],
      "settings": { "foreground": "#8C2E10", "fontStyle": "bold italic" }
    },

    // ── Diff ──────────────────────────────────────────────────
    {
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#2E5828" }
    },
    {
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#8C2E10" }
    },
    {
      "scope": ["markup.changed"],
      "settings": { "foreground": "#7A5010" }
    },
    {
      "scope": ["invalid"],
      "settings": { "foreground": "#1E1410", "background": "#8C2E1025" }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": { "foreground": "#7A5010", "fontStyle": "strikethrough" }
    }
  ],

  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace":                "#1E1410",
    "class":                    "#6B4A08",
    "enum":                     "#7A5A10",
    "interface":                "#7A5A10",
    "struct":                   "#6B4A08",
    "typeParameter":            "#6B4A08",
    "type":                     "#6B4A08",
    "function":                 "#8C4A20",
    "method":                   "#8C4A20",
    "decorator":                { "foreground": "#7A5010", "italic": true },
    "macro":                    "#8C4A20",
    "variable":                 "#1E1410",
    "variable.readonly":        "#7A5010",
    "variable.readonly.static": "#7A5010",
    "parameter":                { "foreground": "#5C3E28", "italic": true },
    "property":                 "#1E1410",
    "property.readonly":        "#7A5010",
    "enumMember":               "#7A5010",
    "event":                    "#8C4A20",
    "keyword":                  { "foreground": "#7A2010", "bold": true },
    "label":                    "#7A5010",
    "comment":                  { "foreground": "#A89A82", "italic": true },
    "string":                   "#245C40",
    "number":                   "#7A5010",
    "operator":                 "#6A5848",
    "regexp":                   "#7A5010",
    "lifetime":                 { "foreground": "#7A5010", "italic": true },
    "selfKeyword":              { "foreground": "#245C40", "italic": true },
    "builtinType":              "#6B4A08",
    "formatSpecifier":          "#8C4A20"
  }
}
