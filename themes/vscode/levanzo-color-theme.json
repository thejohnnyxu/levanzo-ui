{
  "name": "Levanzo",
  "$schema": "vscode://schemas/color-theme",
  "type": "light",

  "colors": {
    // ── Philosophy ────────────────────────────────────────────
    // One warm parchment family. No jarring jumps.
    // Every chrome surface lives within a ~15 point lightness band.
    // Only the editor steps out — slightly lighter & warmer.
    // No espresso nav; the activity bar stays in the same family.
    //
    // Base tone:    #D8D2C8  (warm grey-stone, the "floor")
    // Chrome:       #D0CAC0  (most panels, sidebar, tabs — same family)
    // Editor:       #E8E2D8  (just enough lift to read comfortably)
    // Borders:      #C4BEB4  (subtle, same hue, ~10pt darker)
    // Activity bar: #2C2418  (the one intentional anchor — nav-bg)

    // ── Editor ───────────────────────────────────────────────
    "editor.background":                      "#EDE6D8",
    "editor.foreground":                      "#1E1410",
    "editorLineNumber.foreground":            "#C0B09A",
    "editorLineNumber.activeForeground":      "#887060",
    "editor.lineHighlightBackground":         "#E0DAD020",
    "editor.lineHighlightBorder":             "#00000000",
    "editor.selectionBackground":             "#A85C3840",
    "editor.selectionHighlightBackground":    "#A85C3820",
    "editor.wordHighlightBackground":         "#5E785830",
    "editor.wordHighlightStrongBackground":   "#5E785848",
    "editor.findMatchBackground":             "#9E722880",
    "editor.findMatchHighlightBackground":    "#9E722840",
    "editor.rangeHighlightBackground":        "#A85C3815",
    "editor.hoverHighlightBackground":        "#A85C3818",
    "editorCursor.foreground":                "#A85C38",
    "editorCursor.background":                "#EDE6D8",
    "editor.inactiveSelectionBackground":     "#A85C3820",

    // ── Gutter ───────────────────────────────────────────────
    "editorGutter.background":                "#EDE6D8",
    "editorGutter.addedBackground":           "#5E7858",
    "editorGutter.modifiedBackground":        "#9E7228",
    "editorGutter.deletedBackground":         "#A85C38",

    // ── Indent guides ─────────────────────────────────────────
    "editorWhitespace.foreground":            "#C8C2B820",
    "editorIndentGuide.background":           "#D4CEC4",
    "editorIndentGuide.activeBackground":     "#B0A494",
    "editorBracketMatch.background":          "#9E722830",
    "editorBracketMatch.border":              "#9E7228",

    // ── Overview ruler ────────────────────────────────────────
    "editorOverviewRuler.border":             "#C4BEB4",
    "editorOverviewRuler.findMatchForeground":"#9E7228",
    "editorOverviewRuler.selectionHighlightForeground": "#A85C38",
    "editorOverviewRuler.modifiedForeground": "#9E7228",
    "editorOverviewRuler.addedForeground":    "#5E7858",
    "editorOverviewRuler.deletedForeground":  "#A85C38",
    "editorOverviewRuler.errorForeground":    "#A85C38",
    "editorOverviewRuler.warningForeground":  "#9E7228",

    // ── Squiggles ─────────────────────────────────────────────
    "editorError.foreground":                 "#A85C38",
    "editorWarning.foreground":               "#9E7228",
    "editorInfo.foreground":                  "#5E7858",

    // ── Widgets (suggest, hover, peek) ────────────────────────
    "editorSuggestWidget.background":         "#D8D2C8",
    "editorSuggestWidget.border":             "#C4BEB4",
    "editorSuggestWidget.foreground":         "#28201A",
    "editorSuggestWidget.highlightForeground":"#A85C38",
    "editorSuggestWidget.selectedBackground": "#C4BEB4",
    "editorSuggestWidget.selectedForeground": "#28201A",
    "editorHoverWidget.background":           "#D8D2C8",
    "editorHoverWidget.border":               "#C4BEB4",
    "editorHoverWidget.foreground":           "#28201A",
    "peekView.border":                        "#A85C38",
    "peekViewEditor.background":              "#EDE6D8",
    "peekViewEditor.matchHighlightBackground":"#A85C3840",
    "peekViewResult.background":              "#D0CAC0",
    "peekViewResult.fileForeground":          "#28201A",
    "peekViewResult.lineForeground":          "#80706A",
    "peekViewResult.matchHighlightBackground":"#A85C3850",
    "peekViewResult.selectionBackground":     "#C4BEB4",
    "peekViewResult.selectionForeground":     "#28201A",
    "peekViewTitle.background":               "#D0CAC0",
    "peekViewTitleDescription.foreground":    "#80706A",
    "peekViewTitleLabel.foreground":          "#28201A",

    // ── Diff ──────────────────────────────────────────────────
    "diffEditor.insertedTextBackground":      "#5E785820",
    "diffEditor.removedTextBackground":       "#A85C3820",
    "diffEditor.insertedLineBackground":      "#5E785810",
    "diffEditor.removedLineBackground":       "#A85C3810",

    // ── Activity bar ──────────────────────────────────────────
    // Intentional anchor — matches --nav-bg, same as Notte
    "activityBar.background":                 "#2C2418",
    "activityBar.foreground":                 "#D8D0C0",
    "activityBar.inactiveForeground":         "#78685A",
    "activityBar.border":                     "#221C14",
    "activityBarBadge.background":            "#A85C38",
    "activityBarBadge.foreground":            "#E8E2D8",
    "activityBar.activeBorder":               "#BE7A54",
    "activityBar.activeBackground":           "#00000000",

    // ── Side bar ──────────────────────────────────────────────
    // Same tone as chrome floor — no jump between file area and empty area
    "sideBar.background":                     "#D8D2C8",
    "sideBar.foreground":                     "#30241C",
    "sideBar.border":                         "#C4BEB4",
    "sideBarTitle.foreground":                "#70584A",
    "sideBarSectionHeader.background":        "#D8D2C8",
    "sideBarSectionHeader.foreground":        "#70584A",
    "sideBarSectionHeader.border":            "#C8C2B8",
    "sideBar.dropBackground":                 "#A85C3818",

    // ── List / file explorer ──────────────────────────────────
    "list.activeSelectionBackground":         "#C8C2B8",
    "list.activeSelectionForeground":         "#28201A",
    "list.inactiveSelectionBackground":       "#CEC8BE",
    "list.inactiveSelectionForeground":       "#28201A",
    "list.hoverBackground":                   "#D0CAC0",
    "list.hoverForeground":                   "#28201A",
    "list.focusBackground":                   "#C8C2B8",
    "list.focusForeground":                   "#28201A",
    "list.dropBackground":                    "#A85C3818",
    "list.highlightForeground":               "#A85C38",
    "list.invalidItemForeground":             "#A85C38",
    "list.errorForeground":                   "#A85C38",
    "list.warningForeground":                 "#9E7228",
    "listFilterWidget.background":            "#D8D2C8",
    "listFilterWidget.outline":               "#A85C38",
    "listFilterWidget.noMatchesOutline":      "#A85C38",
    "tree.indentGuidesStroke":                "#C4BEB4",

    // ── Status bar ────────────────────────────────────────────
    "statusBar.background":                   "#2C2418",
    "statusBar.foreground":                   "#A89070",
    "statusBar.border":                       "#221C14",
    "statusBar.noFolderBackground":           "#2C2418",
    "statusBar.debuggingBackground":          "#A85C38",
    "statusBar.debuggingForeground":          "#E8E2D8",
    "statusBarItem.remoteBackground":         "#A85C38",
    "statusBarItem.remoteForeground":         "#E8E2D8",
    "statusBarItem.hoverBackground":          "#FFFFFF15",
    "statusBarItem.activeBackground":         "#FFFFFF22",
    "statusBarItem.errorBackground":          "#A85C3870",
    "statusBarItem.warningBackground":        "#9E722870",

    // ── Title bar ─────────────────────────────────────────────
    // Same warm chrome family — not espresso
    "titleBar.activeBackground":              "#D0CAC0",
    "titleBar.activeForeground":              "#28201A",
    "titleBar.inactiveBackground":            "#D0CAC0",
    "titleBar.inactiveForeground":            "#90807A",
    "titleBar.border":                        "#C4BEB4",

    // ── Menus ─────────────────────────────────────────────────
