    "menu.foreground":                        "#28201A",
    "menu.selectionBackground":               "#C8C2B8",
    "menu.selectionForeground":               "#28201A",
    "menu.separatorBackground":               "#C4BEB4",
    "menu.border":                            "#C4BEB4",
