    "menubar.selectionForeground":            "#28201A",

    // ── Tabs ──────────────────────────────────────────────────
    // Active tab matches editor exactly — seamless join
    // Inactive tabs match chrome floor — no jump
    "tab.activeBackground":                   "#EDE6D8",
    "tab.activeForeground":                   "#28201A",
    "tab.activeBorderTop":                    "#A85C38",
    "tab.activeBorder":                       "#00000000",
    "tab.inactiveBackground":                 "#D0CAC0",
    "tab.inactiveForeground":                 "#80706A",
    "tab.hoverBackground":                    "#D8D2C8",
    "tab.hoverForeground":                    "#30241C",
    "tab.border":                             "#C4BEB4",
    "tab.unfocusedActiveBackground":          "#EDE6D8",
    "tab.unfocusedActiveForeground":          "#60504A",
    "tab.unfocusedInactiveBackground":        "#D0CAC0",
    "tab.unfocusedInactiveForeground":        "#A09088",
    "editorGroupHeader.tabsBackground":       "#D0CAC0",
    "editorGroupHeader.tabsBorder":           "#C4BEB4",
    "editorGroupHeader.noTabsBackground":     "#EDE6D8",
    "editorGroup.border":                     "#C4BEB4",
    "editorGroup.dropBackground":             "#A85C3818",

    // ── Panels / terminal ─────────────────────────────────────
