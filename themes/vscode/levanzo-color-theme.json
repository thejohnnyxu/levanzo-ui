    "settings.modifiedItemIndicator":         "#A85C38",
    "settings.focusedRowBackground":          "#D0CAC040",
    "settings.rowHoverBackground":            "#E8E2D840",
    "settings.dropdownBackground":            "#D8D2C8",
    "settings.dropdownBorder":                "#C4BEB4",
    "settings.dropdownForeground":            "#28201A",
