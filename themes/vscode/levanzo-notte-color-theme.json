  "tokenColors": [
    // ── Base ──────────────────────────────────────────────────
    {
      "name": "Default text",
      "scope": ["source", "text"],
      "settings": { "foreground": "#CEBEAA" }
    },
    {
      "name": "Unrecognized / plain text",
      "scope": ["punctuation", "meta.brace"],
      "settings": { "foreground": "#A89070" }
    },

    // ── Comments ──────────────────────────────────────────────
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#60503A", "fontStyle": "italic" }
    },
    {
      "name": "Doc block comments",
      "scope": ["comment.block.documentation"],
      "settings": { "foreground": "#6E6048", "fontStyle": "italic" }
    },

    // ── Strings ───────────────────────────────────────────────
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.interpolated"
      ],
      "settings": { "foreground": "#8AA884" }
    },
    {
      "name": "String escapes",
      "scope": ["constant.character.escape"],
      "settings": { "foreground": "#D0A454" }
    },
    {
      "name": "String interpolation punctuation",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": { "foreground": "#D48C64" }
    },
    {
      "name": "Regex",
      "scope": ["string.regexp", "constant.other.character-class.regexp"],
      "settings": { "foreground": "#D0A454" }
    },
    {
      "name": "Regex quantifiers / anchors",
      "scope": [
        "keyword.operator.quantifier.regexp",
        "keyword.control.anchor.regexp",
        "punctuation.definition.group.regexp"
      ],
      "settings": { "foreground": "#C07048" }
    },

    // ── Numbers ───────────────────────────────────────────────
    {
      "name": "Numbers",
      "scope": ["constant.numeric", "constant.other.numeric"],
      "settings": { "foreground": "#D0A454" }
    },

    // ── Constants & booleans ──────────────────────────────────
    {
      "name": "Language constants (true, false, null, undefined)",
      "scope": [
        "constant.language",
        "variable.language.this",
        "variable.language.super",
        "variable.language.self"
      ],
      "settings": { "foreground": "#8AA884", "fontStyle": "italic" }
    },
    {
      "name": "Built-in constants",
      "scope": ["constant.other"],
      "settings": { "foreground": "#D0A454" }
    },

    // ── Keywords ──────────────────────────────────────────────
    {
      "name": "Keywords",
      "scope": ["keyword", "keyword.control", "keyword.operator.new"],
      "settings": { "foreground": "#C07048" }
    },
    {
      "name": "Import / export keywords",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as",
        "keyword.control.of",
        "keyword.control.in"
      ],
      "settings": { "foreground": "#C07048" }
    },
    {
      "name": "Return / throw",
      "scope": [
        "keyword.control.return",
        "keyword.control.throw",
        "keyword.control.yield"
      ],
      "settings": { "foreground": "#C07048", "fontStyle": "italic" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#A89070" }
    },
    {
      "name": "Assignment operator",
      "scope": ["keyword.operator.assignment"],
      "settings": { "foreground": "#CEBEAA" }
    },
    {
      "name": "Arrow operator",
      "scope": ["storage.type.function.arrow", "keyword.operator.arrow"],
      "settings": { "foreground": "#C07048" }
    },

    // ── Storage / type modifiers ───────────────────────────────
    {
      "name": "Storage (var, let, const, function, class, etc.)",
      "scope": ["storage", "storage.type"],
      "settings": { "foreground": "#C07048" }
    },
    {
      "name": "Storage modifiers (async, static, export, public, etc.)",
      "scope": ["storage.modifier"],
      "settings": { "foreground": "#C07048", "fontStyle": "italic" }
    },

    // ── Functions ─────────────────────────────────────────────
    {
      "name": "Function declarations",
      "scope": [
        "entity.name.function",
        "meta.function entity.name.function"
      ],
      "settings": { "foreground": "#E4D8C0" }
    },
    {
      "name": "Function calls",
      "scope": [
        "meta.function-call entity.name.function",
        "variable.function"
      ],
      "settings": { "foreground": "#D48C64" }
    },
    {
      "name": "Built-in functions",
      "scope": [
        "support.function",
        "support.function.builtin"
      ],
      "settings": { "foreground": "#D48C64" }
    },
    {
      "name": "Method calls",
      "scope": [
        "meta.method-call entity.name.function",
        "support.function.method"
      ],
      "settings": { "foreground": "#D48C64" }
    },

    // ── Classes / types ───────────────────────────────────────
    {
      "name": "Class / type names",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.name.type.class",
        "support.class",
        "support.type"
      ],
      "settings": { "foreground": "#B88838" }
    },
    {
      "name": "Inherited class",
      "scope": ["entity.other.inherited-class"],
      "settings": { "foreground": "#D0A454", "fontStyle": "italic" }
    },
    {
      "name": "Type annotations / generics",
      "scope": [
        "meta.type.annotation",
        "entity.name.type.ts",
        "entity.name.type.parameter"
      ],
      "settings": { "foreground": "#B88838" }
    },
    {
      "name": "Interface name",
      "scope": ["entity.name.type.interface"],
      "settings": { "foreground": "#D0A454" }
    },
    {
      "name": "Namespace / module",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "entity.name.type.module"
      ],
      "settings": { "foreground": "#CEBEAA" }
    },

    // ── Variables ─────────────────────────────────────────────
    {
      "name": "Variables",
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#CEBEAA" }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#C4AE90", "fontStyle": "italic" }
    },
    {
      "name": "Object properties",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key"
      ],
      "settings": { "foreground": "#CEBEAA" }
    },
    {
      "name": "Destructuring variable",
      "scope": ["variable.other.readwrite.alias"],
      "settings": { "foreground": "#CEBEAA" }
    },
    {
      "name": "Constant variable (all-caps convention)",
      "scope": ["variable.other.constant"],
      "settings": { "foreground": "#D0A454" }
    },

    // ── Imports ───────────────────────────────────────────────
    {
      "name": "Import paths",
      "scope": ["string.quoted.double.import", "string.quoted.single.import"],
      "settings": { "foreground": "#8AA884" }
    },

    // ── Decorators / annotations ───────────────────────────────
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator",
        "storage.type.function.decorator"
      ],
      "settings": { "foreground": "#D0A454", "fontStyle": "italic" }
    },

    // ── HTML / JSX / Templates ────────────────────────────────
    {
      "name": "HTML tag names",
      "scope": [
        "entity.name.tag",
        "meta.tag entity.name.tag"
      ],
      "settings": { "foreground": "#C07048" }
    },
    {
      "name": "HTML attributes",
      "scope": [
        "entity.other.attribute-name",
        "meta.tag entity.other.attribute-name"
      ],
      "settings": { "foreground": "#D0A454" }
    },
    {
      "name": "HTML attribute values",
      "scope": [
        "string.quoted.double.html",
        "string.quoted.single.html"
      ],
      "settings": { "foreground": "#8AA884" }
    },
    {
      "name": "JSX component names",
      "scope": [
        "support.class.component",
        "entity.name.tag.jsx",
        "entity.name.tag.tsx"
      ],
      "settings": { "foreground": "#B88838" }
    },
    {
      "name": "JSX expression braces",
      "scope": ["punctuation.section.embedded.begin.jsx", "punctuation.section.embedded.end.jsx"],
      "settings": { "foreground": "#D48C64" }
