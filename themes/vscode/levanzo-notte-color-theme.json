      "settings": { "foreground": "#D0A454" }
    },
    {
      "name": "CSS property names",
      "scope": ["support.type.property-name.css", "meta.property-name"],
      "settings": { "foreground": "#CEBEAA" }
    },
    {
      "name": "CSS property values",
      "scope": [
        "support.constant.property-value.css",
        "meta.property-value"
      ],
      "settings": { "foreground": "#8AA884" }
    },
    {
      "name": "CSS units",
      "scope": [
        "keyword.other.unit.css",
        "constant.numeric.css"
      ],
      "settings": { "foreground": "#D0A454" }
    },
    {
      "name": "CSS variables / custom properties",
      "scope": [
        "variable.css",
        "support.type.custom-property",
        "support.type.variable-name.css"
      ],
      "settings": { "foreground": "#C07048" }
    },
    {
      "name": "CSS @ rules",
      "scope": ["keyword.control.at-rule", "keyword.other.at-rule"],
      "settings": { "foreground": "#C07048", "fontStyle": "italic" }
    },
    {
      "name": "CSS pseudo-classes / pseudo-elements",
      "scope": [
        "entity.other.pseudo-class.css",
        "entity.other.pseudo-element.css"
      ],
      "settings": { "foreground": "#D48C64" }
    },
    {
      "name": "CSS hex colors",
      "scope": ["constant.other.color.rgb-value.css"],
      "settings": { "foreground": "#D0A454" }
    },

    // ── Markdown ──────────────────────────────────────────────
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "markup.heading.markdown"
      ],
      "settings": { "foreground": "#E4D8C0", "fontStyle": "bold" }
    },
    {
      "name": "Markdown heading hashes",
      "scope": ["punctuation.definition.heading.markdown"],
      "settings": { "foreground": "#C07048" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#E4D8C0", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#CEBEAA", "fontStyle": "italic" }
    },
    {
      "name": "Markdown inline code",
      "scope": ["markup.inline.raw", "markup.raw.inline"],
      "settings": { "foreground": "#8AA884" }
    },
    {
      "name": "Markdown code blocks",
      "scope": ["markup.fenced_code.block", "markup.raw.block"],
      "settings": { "foreground": "#CEBEAA" }
    },
    {
      "name": "Markdown links",
      "scope": ["markup.underline.link"],
      "settings": { "foreground": "#C07048" }
    },
    {
      "name": "Markdown link text",
      "scope": ["string.other.link.title.markdown"],
      "settings": { "foreground": "#D48C64" }
    },
    {
      "name": "Markdown blockquote",
      "scope": ["markup.quote"],
      "settings": { "foreground": "#847058", "fontStyle": "italic" }
    },
    {
      "name": "Markdown list bullets",
      "scope": [
        "punctuation.definition.list.begin.markdown",
        "markup.list.bullet"
      ],
      "settings": { "foreground": "#C07048" }
    },
    {
      "name": "Markdown hr",
      "scope": ["meta.separator.markdown"],
      "settings": { "foreground": "#38302A" }
    },

    // ── JSON ──────────────────────────────────────────────────
    {
      "name": "JSON property keys",
      "scope": ["support.type.property-name.json", "string.json meta.structure.dictionary.json"],
      "settings": { "foreground": "#CEBEAA" }
    },
    {
      "name": "JSON string values",
      "scope": ["string.quoted.json"],
      "settings": { "foreground": "#8AA884" }
    },
    {
      "name": "JSON numbers",
      "scope": ["constant.numeric.json"],
      "settings": { "foreground": "#D0A454" }
    },
    {
      "name": "JSON boolean / null",
      "scope": ["constant.language.json"],
      "settings": { "foreground": "#8AA884", "fontStyle": "italic" }
    },

    // ── YAML ──────────────────────────────────────────────────
    {
      "name": "YAML keys",
      "scope": ["entity.name.tag.yaml"],
      "settings": { "foreground": "#CEBEAA" }
    },
    {
      "name": "YAML anchors / aliases",
      "scope": ["entity.name.type.anchor.yaml", "variable.other.alias.yaml"],
      "settings": { "foreground": "#D0A454" }
    },
    {
      "name": "YAML strings",
      "scope": ["string.unquoted.yaml", "string.quoted.yaml"],
      "settings": { "foreground": "#8AA884" }
    },

    // ── Python ────────────────────────────────────────────────
    {
      "name": "Python decorators",
      "scope": ["entity.name.function.decorator.python"],
      "settings": { "foreground": "#D0A454", "fontStyle": "italic" }
    },
    {
      "name": "Python self",
      "scope": ["variable.language.special.self.python"],
      "settings": { "foreground": "#8AA884", "fontStyle": "italic" }
    },
    {
      "name": "Python magic functions",
      "scope": ["support.function.magic.python"],
      "settings": { "foreground": "#D48C64" }
    },
    {
      "name": "Python f-string braces",
      "scope": ["meta.interpolation.python"],
      "settings": { "foreground": "#D48C64" }
    },

    // ── Rust ──────────────────────────────────────────────────
    {
      "name": "Rust lifetime annotations",
      "scope": ["storage.modifier.lifetime.rust", "entity.name.lifetime.rust"],
      "settings": { "foreground": "#D0A454", "fontStyle": "italic" }
    },
    {
      "name": "Rust macros",
      "scope": ["entity.name.function.macro.rust", "support.macro.rust"],
      "settings": { "foreground": "#D48C64" }
    },
    {
      "name": "Rust unsafe",
      "scope": ["storage.modifier.unsafe.rust"],
      "settings": { "foreground": "#C07048", "fontStyle": "bold italic" }
    },

    // ── Shell ─────────────────────────────────────────────────
    {
      "name": "Shell variable expansion",
      "scope": [
        "variable.other.dollar.only.shell",
        "punctuation.definition.variable.shell"
      ],
      "settings": { "foreground": "#D48C64" }
    },
    {
      "name": "Shell flags",
      "scope": ["string.unquoted.argument.shell"],
      "settings": { "foreground": "#CEBEAA" }
    },

    // ── Diff ──────────────────────────────────────────────────
    {
      "name": "Diff added",
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#8AA884" }
    },
    {
      "name": "Diff deleted",
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#C07048" }
    },
    {
      "name": "Diff changed",
      "scope": ["markup.changed"],
      "settings": { "foreground": "#D0A454" }
    },
    {
      "name": "Diff header",
      "scope": ["meta.diff.header"],
      "settings": { "foreground": "#847058", "fontStyle": "italic" }
    },

    // ── Invalid ───────────────────────────────────────────────
    {
      "name": "Invalid",
      "scope": ["invalid"],
      "settings": { "foreground": "#E4D8C0", "background": "#C0704850" }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": { "foreground": "#D0A454", "fontStyle": "strikethrough" }
    }
  ],

  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace":              "#CEBEAA",
    "class":                  "#B88838",
    "enum":                   "#D0A454",
    "interface":              "#D0A454",
    "struct":                 "#B88838",
    "typeParameter":          "#B88838",
    "type":                   "#B88838",
    "function":               "#D48C64",
    "method":                 "#D48C64",
    "decorator":              { "foreground": "#D0A454", "italic": true },
    "macro":                  "#D48C64",
    "variable":               "#CEBEAA",
    "variable.readonly":      "#D0A454",
    "variable.readonly.static": "#D0A454",
    "parameter":              { "foreground": "#C4AE90", "italic": true },
    "property":               "#CEBEAA",
    "property.readonly":      "#D0A454",
    "enumMember":             "#D0A454",
    "event":                  "#D48C64",
    "keyword":                "#C07048",
    "label":                  "#D0A454",
    "comment":                { "foreground": "#60503A", "italic": true },
    "string":                 "#8AA884",
    "number":                 "#D0A454",
    "operator":               "#A89070",
    "regexp":                 "#D0A454",
    "lifetime":               { "foreground": "#D0A454", "italic": true },
    "selfKeyword":            { "foreground": "#8AA884", "italic": true },
    "builtinType":            "#B88838",
    "formatSpecifier":        "#D48C64"
  }
}
